{
  "openapi": "3.0.4",
  "info": {
    "title": "TomSandboxWMS API",
    "version": "1.0"
  },
  "paths": {
    "/v1/goods-receipts/{goodsReceiptId}/complete-scan": {
      "post": {
        "tags": [
          "GoodsReceipts"
        ],
        "operationId": "CompleteScan",
        "parameters": [
          {
            "name": "goodsReceiptId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
