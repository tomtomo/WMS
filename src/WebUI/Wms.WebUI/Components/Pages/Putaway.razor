@page "/inventory/putaway"
@using System.Security.Claims
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar

<PageTitle>WMS — Putaway</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Putaway Tasks</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
}
else if (_tasks.Count == 0)
{
    <MudText>Tidak ada task putaway.</MudText>
}
else
{
    <MudTable Items="_tasks" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Stock</MudTh>
            <MudTh>Suggested Destination</MudTh>
            <MudTh>Status</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Stock">@Short(context.StockId)</MudTd>
            <MudTd DataLabel="Suggested Destination">@Short(context.SuggestedDestinationId)</MudTd>
            <MudTd DataLabel="Status">@context.Status</MudTd>
            <MudTd>
                @if (_user.HasPermission(UiPermissions.CompletePutaway))
                {
                    <MudButton Size="Size.Small" Color="Color.Success" Disabled="_busy"
                               OnClick="() => CompleteAsync(context)">Complete</MudButton>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<PutawayItem> _tasks = [];
    private bool _loading;
    private bool _busy;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private ClaimsPrincipal _user = new(new ClaimsIdentity());

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is not null)
        {
            _user = (await AuthStateTask).User;
        }

        await LoadAsync();
    }

    private HttpClient Client => HttpClientFactory.CreateClient(BffExtensions.GatewayClientName);

    private static string Short(Guid id) => id.ToString()[..8];

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _tasks = await Client.GetFromJsonAsync<List<PutawayItem>>("/inventory/v1/putaway-tasks") ?? [];
        }
        catch (HttpRequestException)
        {
            Snackbar.Add("Gagal memuat task putaway.", Severity.Warning);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CompleteAsync(PutawayItem task)
    {
        _busy = true;
        try
        {
            // Operator menaruh ke lokasi yang disarankan (default lab).
            var body = new { actualDestinationId = task.SuggestedDestinationId, operatorId = (Guid?)null };
            var response = await Client.PostAsJsonAsync(
                $"/inventory/v1/putaway-tasks/{task.PutawayTaskId}/complete", body);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Putaway selesai.", Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add($"Gagal ({(int)response.StatusCode}).", Severity.Error);
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed record PutawayItem(
        Guid PutawayTaskId,
        Guid StockId,
        Guid SourceLocationId,
        Guid SuggestedDestinationId,
        Guid AssignedTo,
        string Status,
        Guid? ActualDestinationId);
}
