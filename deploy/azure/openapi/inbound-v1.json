  "components": {
    "schemas": {
      "CreateGoodsReceiptRequest": {
        "type": "object",
        "properties": {
          "poRef": {
            "type": "string",
            "nullable": true
          },
          "supplierId": {
            "type": "string",
            "format": "uuid"
          },
          "warehouseId": {
            "type": "string",
            "format": "uuid"
          },
          "dockDoor": {
            "type": "string",
            "nullable": true
          },
          "expectedLines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExpectedLineRequest"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ExpectedLineRequest": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string",
            "nullable": true
          },
          "expectedQty": {
            "type": "number",
            "format": "double"
          },
          "uom": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "HoldGoodsReceiptRequest": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ResolveDiscrepancyRequest": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "nullable": true
          },
          "note": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ScanReceiptLineRequest": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string",
            "nullable": true
          },
          "actualQty": {
            "type": "number",
            "format": "double"
          },
          "batch": {
            "type": "string",
            "nullable": true
          },
          "expiry": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "lineStatus": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "GoodsReceipts"
    }
  ]
}