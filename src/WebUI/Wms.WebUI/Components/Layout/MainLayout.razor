@inherits LayoutComponentBase

<MudThemeProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6" Class="mr-4">TomSandbox WMS</MudText>
        <MudSpacer />
        <MudButton Href="/" Color="Color.Inherit">Home</MudButton>
        <MudButton Href="/inbox" Color="Color.Inherit">Inbox</MudButton>
        <MudButton Href="/reports/stock" Color="Color.Inherit">Stock</MudButton>
        <MudButton Href="/login" Color="Color.Inherit">Login</MudButton>
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
