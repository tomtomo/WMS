  </ItemGroup>

  <ItemGroup Label="Protocol - gRPC server, codegen proto">
    <PackageReference Include="Grpc.AspNetCore" />
  </ItemGroup>

  <ItemGroup Label="Kontrak proto internal (server, client stub untuk integration test)">
    <Protobuf Include="Protos\inbound.v1.proto" GrpcServices="Both" />
  </ItemGroup>

  <ItemGroup Label="Application, published language, kernel Web">
    <ProjectReference Include="..\Wms.Inbound.Application\Wms.Inbound.Application.csproj" />
    <ProjectReference Include="..\Wms.Inbound.Contracts\Wms.Inbound.Contracts.csproj" />
    <ProjectReference Include="..\..\..\BuildingBlocks\Wms.BuildingBlocks.Web\Wms.BuildingBlocks.Web.csproj" />
  </ItemGroup>

</Project>
