<Project Sdk="Microsoft.NET.Sdk">

  <!-- Infrastructure layer Auth: EF persistence (schema 'auth'), JWT RS256 issuer (sign side), Argon2id reuse via port. -->

  <ItemGroup Label="Persistence - EF Core, Npgsql, snake case">
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    <PackageReference Include="EFCore.NamingConventions" />
  </ItemGroup>

  <ItemGroup Label="Design time - dotnet ef migrations">
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup Label="Security - JWT RS256 issuance">
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" />
  </ItemGroup>

  <ItemGroup Label="Composition - DI">
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>

  <ItemGroup Label="Test">
    <InternalsVisibleTo Include="Wms.Auth.IntegrationTests" />
  </ItemGroup>

  <ItemGroup Label="Application, mekanisme rail">
    <ProjectReference Include="..\Wms.Auth.Application\Wms.Auth.Application.csproj" />
    <ProjectReference Include="..\..\..\BuildingBlocks\Wms.BuildingBlocks.Infrastructure\Wms.BuildingBlocks.Infrastructure.csproj" />
  </ItemGroup>

</Project>
