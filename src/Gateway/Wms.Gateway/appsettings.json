{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "Jwt": {
    "Issuer": "wms-local",
    "Audience": "wms-local",
    "PublicKeyPem": ""
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth",
        "AuthorizationPolicy": "anonymous",
        "Match": { "Path": "/auth/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ]
      },
      "inbound": {
        "ClusterId": "inbound",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/inbound/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/inbound" } ]
      },
      "inventory": {
        "ClusterId": "inventory",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/inventory/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/inventory" } ]
      },
      "outbound": {
        "ClusterId": "outbound",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/outbound/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/outbound" } ]
      },
      "masterdata": {
        "ClusterId": "masterdata",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/masterdata/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/masterdata" } ]
      },
      "reporting": {
        "ClusterId": "reporting",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/reporting/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/reporting" } ]
      },
      "notifications": {
        "ClusterId": "notifications",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/notifications/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/notifications" } ]
      },
      "notifications-hub": {
        "ClusterId": "notifications",
        "AuthorizationPolicy": "anonymous",
        "Match": { "Path": "/hubs/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth": { "Destinations": { "host": { "Address": "https://wms-auth" } } },
      "inbound": { "Destinations": { "host": { "Address": "https://wms-inbound" } } },
      "inventory": { "Destinations": { "host": { "Address": "https://wms-inventory" } } },
      "outbound": { "Destinations": { "host": { "Address": "https://wms-outbound" } } },
      "masterdata": { "Destinations": { "host": { "Address": "https://wms-masterdata" } } },
      "reporting": { "Destinations": { "host": { "Address": "https://wms-reporting" } } },
      "notifications": { "Destinations": { "host": { "Address": "https://wms-notifications" } } }
    }
  }
}
