    "/v1/goods-receipts/{goodsReceiptId}/attachments/{attachmentId}": {
      "delete": {
        "tags": [
          "GoodsReceipts"
        ],
        "operationId": "SoftDeleteGRAttachment",
        "parameters": [
          {
            "name": "goodsReceiptId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "attachmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
