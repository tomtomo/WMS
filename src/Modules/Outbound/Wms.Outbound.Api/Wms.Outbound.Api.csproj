<Project Sdk="Microsoft.NET.Sdk">

  <!-- Api layer Outbound: REST minimal API IEndpoint /v1/waves + /v1/picking-tasks + gRPC read service outbound.v1 -->

  <ItemGroup Label="Shared framework - minimal API">
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup Label="Protocol - gRPC server, codegen proto">
    <PackageReference Include="Grpc.AspNetCore" />
  </ItemGroup>

  <ItemGroup Label="Kontrak proto internal (server, client stub untuk integration test)">
    <Protobuf Include="Protos\outbound.v1.proto" GrpcServices="Both" />
  </ItemGroup>

  <ItemGroup Label="Application, published language, kernel Web">
    <ProjectReference Include="..\Wms.Outbound.Application\Wms.Outbound.Application.csproj" />
    <ProjectReference Include="..\Wms.Outbound.Contracts\Wms.Outbound.Contracts.csproj" />
    <ProjectReference Include="..\..\..\BuildingBlocks\Wms.BuildingBlocks.Web\Wms.BuildingBlocks.Web.csproj" />
  </ItemGroup>

</Project>
