      "get": {
        "tags": [
          "GoodsReceipts"
        ],
        "operationId": "GetGoodsReceiptReview",
        "parameters": [
          {
            "name": "goodsReceiptId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
