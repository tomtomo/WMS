<?xml version="1.0" encoding="utf-8"?>
<!--
  Satu feed package eksplisit. <clear/> dulu supaya tak ada feed level mesin/user yang
  bocor masuk (restore reproducible lintas mesin dev & CI). Hanya nuget.org.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
