@page "/inbox"
@inject WmsApiClient Api
@inject NotificationState State

<PageTitle>WMS — Inbox</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">In-app Inbox</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
}
else if (_error)
{
    <MudAlert Severity="Severity.Warning">Inbox belum tersedia</MudAlert>
}
else if (_items.Count == 0)
{
    <MudText>Tidak ada notifikasi.</MudText>
}
else
{
    <MudTable Items="_items" Hover="true">
        <HeaderContent>
            <MudTh>Waktu</MudTh>
            <MudTh>Judul</MudTh>
            <MudTh>Status</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Waktu">@context.CreatedAt.LocalDateTime</MudTd>
            <MudTd DataLabel="Judul">@context.Title</MudTd>
            <MudTd DataLabel="Status">@(context.IsRead ? "dibaca" : "baru")</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private IReadOnlyList<InboxItemDto> _items = [];
    private bool _error;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        State.Reset();
        var result = await Api.Notifications.GetInboxAsync(1, 20);
        if (result.Success)
        {
            _items = result.Value!.Items;
        }
        else
        {
            _error = true;
        }

        _loading = false;
    }
}
